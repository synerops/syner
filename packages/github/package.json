{
  "name": "@syner/github",
  "prettier": "@syner/prettier",
  "version": "0.1.2",
  "description": "GitHub App authentication and tools for Syner",
  "license": "MIT",
  "type": "module",
  "bin": "./src/index.ts",
  "exports": {
    ".": "./src/exports.ts",
    "./octokit": "./src/lib/octokit.ts",
    "./events": "./src/events/index.ts",
    "./actions": "./src/actions/index.ts",
    "./tools": "./src/tools/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:ai",
    "@octokit/auth-app": "^7.0.0",
    "@octokit/plugin-throttling": "^9.0.0",
    "@octokit/rest": "^21.0.0",
    "ai": "catalog:ai",
    "zod": "catalog:ai"
  },
  "devDependencies": {
    "@syner/eslint": "workspace:*",
    "@syner/typescript": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synerops/syner.git",
    "directory": "packages/github"
  }
}
