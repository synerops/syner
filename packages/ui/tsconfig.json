{
  "extends": "@syner/typescript/base",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "outDir": null,
    "rootDir": null,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@syner/ui/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
