{
  "name": "@syner/sdk",
  "prettier": "@syner/prettier",
  "version": "0.0.1",
  "description": "Core package for the Syner ecosystem",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./logger": "./src/logger.ts",
    "./errors": "./src/errors.ts",
    "./skills": {
      "browser": "./src/skills/client.ts",
      "default": "./src/skills/index.ts"
    },
    "./agents": "./src/agents/index.ts",
    "./tools": "./src/tools/index.ts",
    "./context": "./src/context/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "catalog:ai",
    "@ai-sdk/gateway": "catalog:ai",
    "@syner/osprotocol": "workspace:*",
    "ai": "catalog:ai",
    "glob": "^10.0.0",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@syner/eslint": "workspace:*",
    "@syner/typescript": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synerops/syner.git",
    "directory": "packages/sdk"
  }
