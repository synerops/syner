{
  "name": "syner",
  "private": true,
  "packageManager": "bun@1.3.2",
  "workspaces": {
    "packages": ["apps/*", "packages/*", "tooling/*"],
    "catalog": {
      "typescript": "^5",
      "eslint": "^9",
      "@types/node": "^20",
      "tailwindcss": "^4",
      "@tailwindcss/postcss": "^4"
    },
    "catalogs": {
      "react19": {
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "next": "16.1.6",
        "@types/react": "^19",
        "@types/react-dom": "^19"
      },
      "ui": {
        "radix-ui": "^1.4.3",
        "lucide-react": "^0.576.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "shadcn": "^3.8.5"
      },
      "ai": {
        "ai": "^6.0.116",
        "@ai-sdk/gateway": "^3.0.0",
        "@ai-sdk/anthropic": "^3.0.58",
        "zod": "^3.23.0"
      }
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "agent-github": "bun packages/github/bin/syner-agent-github",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build --filter='./packages/*' && changeset publish",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "turbo": "^2.8.20"
  }
}
