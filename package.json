{
  "name": "syner",
  "private": true,
  "scripts": {
    "build": "turbo --no-update-notifier run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo lint",
    "clean": "turbo clean && rm -rf .turbo",
    "typecheck": "turbo typecheck",
    "format": "turbo format"
  },
  "devDependencies": {
    "@syner/eslint": "workspace:*",
    "@syner/prettier": "workspace:*",
    "@syner/typescript": "workspace:*",
    "turbo": "^2.8.3"
  },
  "engines": {
    "bun": ">=1.3.1",
    "node": ">=20"
  },
  "packageManager": "bun@1.3.1",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "tooling/*",
      "extensions/*"
    ],
    "overrides": {
      "typescript": "^5",
      "prettier": "^3.6.2",
      "eslint": "^9.37.0",
      "zod": "^4.1.5"
    },
    "catalog": {
      "eslint": "^9.37.0",
      "prettier": "^3.6.2",
      "typescript": "^5.9.3",
      "zod": "^4.1.5"
    },
    "catalogs": {
      "aisdk": {
        "ai": "^6",
        "zod": "^4.1.8"
      },
      "next16": {
        "next": "^16.1.5",
        "next-themes": "^0.4.6",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "@types/node": "^24",
        "@types/react": "^19.2.3",
        "@types/react-dom": "^19.2.3"
      },
      "docs": {
        "fumadocs-core": "^16",
        "fumadocs-mdx": "^13.0.2",
        "fumadocs-ui": "^16",
        "@types/mdx": "^2.0.13"
      },
      "ui": {
        "sonner": "^2.0.7"
      },
      "vercel": {
        "@vercel/analytics": "^1.5.0"
      },
      "osprotocol": {
        "@osprotocol/schema": "^0.2.4"
      }
    }
  }
}
