{
  "name": "syner",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "fumadocs-mdx": "14.2.14"
  },
  "workspaces": {
    "packages": ["apps/*", "packages/*", "tooling/*"],
    "catalog": {
      "typescript": "^5",
      "eslint": "^9",
      "@types/node": "^24",
      "tailwindcss": "^4.3.1",
      "@tailwindcss/postcss": "^4.3.1"
    },
    "catalogs": {
      "react19": {
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "next": "16.2.9",
        "@types/react": "^19",
        "@types/react-dom": "^19"
      },
      "ui": {
        "radix-ui": "^1.6.0",
        "lucide-react": "^1.21.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "shadcn": "^4.11.0"
      },
      "ai": {
        "ai": "^6.0.116",
        "@ai-sdk/gateway": "^3.0.0",
        "@ai-sdk/anthropic": "^3.0.58",
        "zod": "^4.3.6"
      },
      "eve": {
        "eve": "^0.13.4",
        "ai": "7.0.0-beta.178",
        "zod": "^4.4.3"
      }
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "start": "turbo start",
    "agent-github": "bun packages/github/bin/syner-agent-github",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build --filter='./packages/*' && changeset publish",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.10.0"
  }
}
