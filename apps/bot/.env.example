# =============================================================================
# syner.bot Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# For Vercel deployment, add these in Vercel Dashboard → Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Anthropic (required)
# -----------------------------------------------------------------------------
# Get from: https://console.anthropic.com/settings/keys
# Click "Create Key" → copy the key (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# GitHub App (required)
# -----------------------------------------------------------------------------
# Get from: https://github.com/settings/apps/synerbot
# (or your app's settings page)

# App ID: shown at the top of your app's settings page
GITHUB_APP_ID=123456

# Installation ID: after installing the app, check the URL:
# https://github.com/settings/installations/12345678
#                                            ^^^^^^^^ this is the ID
GITHUB_APP_INSTALLATION_ID=12345678

# Private Key: Generate in app settings → "Private keys" → "Generate a private key"
# Paste the entire PEM contents (including BEGIN/END lines)
# For .env files, use quotes and \n for newlines, or use GITHUB_APP_PEM_PATH instead
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Alternative: path to PEM file (use this instead of GITHUB_APP_PRIVATE_KEY)
# GITHUB_APP_PEM_PATH=/path/to/private-key.pem

# Webhook secret: set in app settings → Webhook → Secret
# Used to verify incoming webhooks are from GitHub
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# -----------------------------------------------------------------------------
# Slack (required for Slack agents)
# -----------------------------------------------------------------------------
# Get from: https://api.slack.com/apps → Your App

# Bot Token: OAuth & Permissions → Bot User OAuth Token
# Required scopes: chat:write, channels:history
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Signing Secret: Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# Webhook URL (optional, for outgoing notifications)
# Get from: Incoming Webhooks → Add New Webhook to Workspace
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# -----------------------------------------------------------------------------
# Security (optional but recommended for production)
# -----------------------------------------------------------------------------
# Random string to protect cron endpoints from unauthorized access
# Generate with: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
