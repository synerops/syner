{
  "extends": "@syner/ts-config/base",
  "compilerOptions": {
    // Build handled by bun - this config is only for type checking and IDE
    "incremental": false,
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@syner/cli/*": ["src/cli/*"],
      "@syner/api/*": ["src/api/*"],
      "@syner/bundle/*": ["src/bundle/*"]
    }
  },
  "include": ["index.ts", "src/**/*"],
  "exclude": ["node_modules/**/*", "dist/**/*"]
}
